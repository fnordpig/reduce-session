/* Main layout: left panel 40%, right panel 60% */
#main-container {
    layout: horizontal;
    height: 1fr;
}

#session-list {
    width: 40%;
    min-width: 30;
    border-right: tall $primary-background-lighten-2;
}

#preview-panel {
    width: 60%;
    min-width: 40;
}

#session-tree {
    height: 1fr;
}

#aggregate-stats {
    height: 1;
    dock: bottom;
    background: $primary-background-lighten-1;
    color: $text-muted;
    padding: 0 1;
}

/* Preview pane */
#empty-state {
    height: 1fr;
    content-align-horizontal: center;
    content-align-vertical: middle;
    color: $text-muted;
}

#info-bar {
    height: auto;
    max-height: 7;
    padding: 0 1;
    background: $primary-background-lighten-1;
}

#conversation-log {
    height: 1fr;
    padding: 0 1;
    overflow-y: auto;
}

/* Token gauge colors */
.token-green { color: #00d4aa; }
.token-yellow { color: #ffd700; }
.token-orange { color: #ff8c00; }
.token-red { color: #ff4444; }

/* Conversation roles */
.role-user { color: #6ec1e4; }
.role-assistant { color: #e88a6a; }
.role-tool { color: $text-muted; }
.role-tool-error { color: #ff4444; }

/* Reduce Modal */
ReduceModal {
    align-horizontal: center;
    align-vertical: middle;
}

#reduce-modal-container {
    width: 80;
    max-width: 90%;
    height: auto;
    max-height: 85%;
    border: solid;
    background: $surface;
    padding: 1 2;
    overflow-y: auto;
}

#modal-title {
    text-style: bold;
    width: 100%;
    content-align-horizontal: center;
    content-align-vertical: middle;
    padding-bottom: 1;
}

.modal-section-header {
    color: $accent;
    text-style: bold;
    padding-top: 1;
}

#profile-bar {
    layout: horizontal;
    height: auto;
    padding: 0 0 1 0;
}

.profile-btn {
    width: auto;
    min-width: 12;
    margin: 0 1 0 0;
}

.profile-btn.-active {
    background: $accent;
    color: $text;
    text-style: bold;
}

#modal-actions {
    layout: horizontal;
    height: 3;
    align-horizontal: right;
    align-vertical: middle;
    padding-top: 1;
}

#modal-actions Button {
    margin: 0 0 0 1;
}

#cut-fade-display {
    color: $text-muted;
    content-align-horizontal: center;
    content-align-vertical: middle;
    padding: 1 0;
}

#spinner {
    height: 3;
    content-align-horizontal: center;
    content-align-vertical: middle;
}

/* History Modal — Time Machine */
HistoryModal {
    align-horizontal: center;
    align-vertical: middle;
}

#history-main {
    layout: horizontal;
    height: 1fr;
}

#version-list {
    width: 45%;
    min-width: 30;
    height: 1fr;
    border-right: tall $primary-background-lighten-2;
}

#history-preview {
    width: 55%;
    height: 1fr;
    padding: 0 1;
}

#history-info {
    height: 2;
    padding: 0 0 1 0;
}

#history-conversation {
    height: 1fr;
    overflow-y: auto;
}

